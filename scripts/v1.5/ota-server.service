[Unit]
Description=OTA Server Daemon
After=network.target

[Service]
Type=simple
User=root
ExecStart=/home/arenatech/server/bin/ota-agent \
  -config-url="http://www.arenatech.cn/ota/server-arm64-v1.5/version.yaml" \
  -version-file="/home/arenatech/server/bin/version" \
  -start-cmd="/home/arenatech/server/bin/server-arm64.bin" \
  -check-interval=5m \
  -daemon=true
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target